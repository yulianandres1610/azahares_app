# Credenciales públicas (las mismas que usa la web). Copiá este archivo a .env y completalo.
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
# Base del backend (NestJS). Producción:
EXPO_PUBLIC_API_URL=https://api.azaharesfuel.com
# Token público de Mapbox (pk.*) — mismo que NEXT_PUBLIC_MAPBOX_TOKEN de la web.
# Habilita el mapa real de GPS (Static Images API). Si falta, se ve el mapa decorativo.
EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxx
